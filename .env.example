# Repo-root .env — read by `docker compose` for host-port mapping and project
# naming. Copy to .env for local dev. This file lets several projects' local
# stacks run at the same time without fighting over the default ports.
#
# Pick a unique host-port block per project (container-internal ports never
# change — only the host side). Keep these in sync with backend/.env:
#   - POSTGRES_PORT here must match POSTGRES_PORT in backend/.env and the port
#     inside backend/.env's DATABASE_URL.
#   - REDIS_PORT here must match the port inside backend/.env's REDIS_URL /
#     CELERY_* URLs.
#
# Example offsets if 5432/6379 are taken by another project: 5442/6389, etc.
COMPOSE_PROJECT_NAME=eventgate
POSTGRES_PORT=5432
REDIS_PORT=6379
# Published web ports (browser-facing). Offset per project to run several at once.
BACKEND_PORT=8000
FRONTEND_PORT=3000
