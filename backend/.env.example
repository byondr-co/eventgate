# Copy to .env for local dev
# NOTE: under the Dockerized dev stack (docker compose up), the backend container
# OVERRIDES the DATABASE_URL / REDIS_URL / CELERY_* values below with compose
# service names (postgres:5432, redis:6379). The localhost values here are used
# only when you run the backend directly on the host (uv run runserver).
DEBUG=True
SECRET_KEY=dev-insecure-secret-change-me
ALLOWED_HOSTS=*

# Local DB host port. If you run several projects at once, give each a unique
# host port (see the repo-root .env.example) and keep all three in sync:
#   1. POSTGRES_PORT here    -> points the TEST database at that host port
#   2. the port in DATABASE_URL below -> the DEV server connection
#   3. POSTGRES_PORT in the repo-root .env -> what docker compose publishes
# The container-internal port is always 5432; this is only the host mapping.
POSTGRES_PORT=5432
DATABASE_URL=postgres://eventgate:eventgate@localhost:5432/eventgate
# If you offset REDIS_PORT in the repo-root .env, update the port in all three
# Redis URLs below to match.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:3000
